# Roomora runtime secrets — copy to .env.local and fill in. NEVER commit .env.local.
# Server-side only. Do NOT prefix model/API keys with NEXT_PUBLIC_.

# --- Image generation engine (Phase 0 spike + Phase 3) ---
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
FAL_KEY=
# Optional quality-benchmark fallback:
GEMINI_API_KEY=

# --- Supabase (Phase 2+) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Test/dev endpoints (Phase 2+) ---
# Comma-separated emails allowed to hit /api/dev/* (tester account)
TEST_USER_EMAILS=

# --- Shop this look (affiliate shopping) ---
# Off by default: the "Shop this look" panel shows a "coming soon" teaser.
# Set to "true" only once a real approved affiliate feed (Awin/other) is
# ingested into the products table, to show real shoppable products. Public.
NEXT_PUBLIC_SHOP_LIVE=
# Awin (or other network) product feed CSV download URL + nightly cron secret.
AWIN_FEED_URL=
CRON_SECRET=

# --- Stripe payments (Phase 6) ---
# Server secret key (sk_test_... / sk_live_...). When unset, /api/checkout and
# the webhook return 503 and the buy flow falls back to the mock credit grant.
STRIPE_SECRET_KEY=
# Webhook signing secret (whsec_...) from the Stripe CLI / dashboard endpoint.
STRIPE_WEBHOOK_SECRET=
# Public app origin used for Checkout success/cancel redirects (no secret).
# e.g. http://localhost:3000 in dev, https://roomora.app in prod.
NEXT_PUBLIC_APP_URL=
